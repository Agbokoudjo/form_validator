{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module":"ESNext",
    "lib": ["DOM", "DOM.Iterable","esnext"],
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",  
    "declarationDir": "dist",        //les .d.ts vont dans dist/ à la racine
    "emitDeclarationOnly": true,     // tsc génère UNIQUEMENT les .d.ts, pas les .js
    "allowImportingTsExtensions":false,
    "declarationMap": true,
    "isolatedModules":false,
    "moduleDetection": "force",
    "esModuleInterop": true,
     "noEmit": false, 
    "strict": true,
    "moduleResolution": "bundler",   
    "declaration": true,     
    "allowJs":false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
     "allowSyntheticDefaultImports": true,
    "types": [
      "node"  
    ],
  },
  "include": ["src/**/*", "src/global.d.ts","pdfjs-dist.d.ts"],
  "exclude": ["node_modules","src/main.ts","dist","src/test/**/*"]
}
